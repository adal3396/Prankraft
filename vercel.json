{
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/projects/:path*", "destination": "/projects/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Prank", "value": "You checked the headers? Impressive. 🎭" }
      ]
    }
  ]
}
